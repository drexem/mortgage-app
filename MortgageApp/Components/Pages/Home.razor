@page "/"
@attribute [Authorize]
@rendermode InteractiveServer

@using System.Globalization
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject FinancialDataService DataService

<PageTitle>Finančný prehľad</PageTitle>

@if (loading)
{
    <div class="loading-state">Načítavam finančný prehľad...</div>
}
else
{
    <header class="page-heading">
        <div>
            <p class="eyebrow">Dashboard</p>
            <h1>Tvoj mesačný prehľad</h1>
            <p class="muted">Pravidelný plat, kvartálne bonusy, výdavky, úspory a hypotéka na jednom mieste.</p>
        </div>
        <span class="date-chip">@MonthName(DateTime.Today)</span>
    </header>

    <section class="summary-grid">
        <article class="summary-card">
            <span>Príjem tento mesiac</span>
            <strong>@Money(monthlyIncome)</strong>
            <small>@CurrentMonthIncomeCount príjmových položiek</small>
        </article>
        <article class="summary-card">
            <span>Priemerný príjem</span>
            <strong>@Money(averageMonthlyIncome)</strong>
            <small>priemer najbližších 12 mesiacov</small>
        </article>
        <article class="summary-card">
            <span>Výdavky tento mesiac</span>
            <strong>@Money(monthlyExpenses)</strong>
            <small>@CurrentMonthExpenseCount výdavkových položiek</small>
        </article>
        <article class="summary-card">
            <span>Plánované odkladanie</span>
            <strong>@Money(monthlySavingsContribution + monthlyInvestmentContribution)</strong>
            <small>@Money(monthlySavingsContribution) sporenie · @Money(monthlyInvestmentContribution) investície</small>
        </article>
        <article class="summary-card accent-card">
            <span>Voľné po odložení</span>
            <strong>@Money(monthlyFree)</strong>
            <small>@Money(monthlyFreeBeforeSavings) pred odložením</small>
        </article>
    </section>

    <section class="cashflow-planning-grid">
        <article class="panel">
            <div class="panel-header">
                <div>
                    <p class="eyebrow">Plán odkladania</p>
                    <h2>Ako rozdeliť kladný prebytok</h2>
                </div>
            </div>
            <div class="planning-control">
                <div class="field">
                    <label>Na sporiace účty (%)</label>
                    <input type="number" min="0" max="100" step="1" class="form-control"
                           @bind="SavingsRateInput" @bind:event="oninput" />
                </div>
                <div class="field">
                    <label>Do investícií (%)</label>
                    <input type="number" min="0" max="100" step="1" class="form-control"
                           @bind="InvestmentRateInput" @bind:event="oninput" />
                </div>
                <div class="field">
                    <label>Aktuálne v investíciách</label>
                    <input type="number" min="0" step="100" class="form-control" @bind="currentInvestmentBalance" />
                </div>
                <button class="btn btn-primary" type="button" @onclick="SaveSavingsRateAsync">Uložiť rozdelenie</button>
            </div>
            <p class="muted planning-help">Súčet je vždy 100 %. Pri zmene jedného percenta sa druhé automaticky dopočíta. Investície sa počítajú bez zisku a nové vklady do sporenia idú vždy do najvýhodnejšieho dostupného pásma.</p>
        </article>

        <article class="panel target-estimate">
            <div>
                <p class="eyebrow">Odhad k dátumu</p>
                <h2>Celkové dostupné peniaze</h2>
            </div>
            <InputDate class="form-control" @bind-Value="freeCashTargetDate" />
            <strong class="@(PositionForecast.TotalAvailable >= 0 ? "income-text" : "expense-text")">@Money(PositionForecast.TotalAvailable)</strong>
            <div class="forecast-breakdown">
                <span>Na sporiacich účtoch <strong>@Money(PositionForecast.SavingsBalance)</strong></span>
                <span>Investované <strong>@Money(PositionForecast.InvestmentBalance)</strong></span>
                <span>Hotovosť mimo sporenia <strong>@Money(PositionForecast.CashOutsideSavings)</strong></span>
                <span>Z toho odhad úrokov <strong>@Money(PositionForecast.NetInterest)</strong></span>
            </div>
            <div class="forecast-chart">
                <div class="portfolio-pie @(ForecastChartTotal == 0 ? "empty" : "")" style="@ForecastChartStyle">
                    <span>@SavingsChartShare.ToString("N0") %</span>
                </div>
                <div class="chart-legend">
                    <span><i class="savings-swatch"></i>Sporiace účty <strong>@Money(PositionForecast.SavingsBalance)</strong></span>
                    <span><i class="investment-swatch"></i>Investície <strong>@Money(PositionForecast.InvestmentBalance)</strong></span>
                </div>
            </div>
            <small>odhad zahŕňa aktuálne sporiace účty, budúce príjmy, výdavky, hypotéku, vklady, investície bez výnosu a úroky</small>
        </article>
    </section>

    <section class="dashboard-grid">
        <article class="panel cashflow-panel">
            <div class="panel-header">
                <div>
                    <p class="eyebrow">Cash flow</p>
                    <h2>Príjmy a výdavky</h2>
                </div>
                <span class="balance-pill @(monthlyFree >= 0 ? "positive" : "negative")">@Money(monthlyFree)</span>
            </div>

            <EditForm Model="newEntry" OnValidSubmit="AddEntryAsync" class="cashflow-form">
                <DataAnnotationsValidator />
                <div class="field">
                    <label>Názov</label>
                    <InputText class="form-control" @bind-Value="newEntry.Name" placeholder="Plat alebo kvartálny bonus" />
                </div>
                <div class="field">
                    <label>Suma pri každom pripísaní</label>
                    <InputNumber class="form-control" @bind-Value="newEntry.MonthlyAmount" />
                </div>
                <div class="field">
                    <label>Typ</label>
                    <InputSelect class="form-select" @bind-Value="newEntry.Type">
                        <option value="@CashFlowType.Income">Príjem</option>
                        <option value="@CashFlowType.Expense">Výdavok</option>
                    </InputSelect>
                </div>
                <div class="field">
                    <label>Opakovať každých X mesiacov (voliteľné)</label>
                    <InputNumber class="form-control" @bind-Value="newEntry.IntervalMonths" placeholder="Jednorazová položka" />
                </div>
                <div class="field">
                    <label>Prvý mesiac</label>
                    <InputDate class="form-control" @bind-Value="newEntry.FirstOccurrenceMonth" />
                </div>
                <button class="btn btn-primary" type="submit">Pridať položku</button>
            </EditForm>

            <div class="frequency-help">
                Pole opakovania nechaj prázdne pre jednorazovú položku. Mesačný plat nastav na
                <strong>1</strong>, kvartálny bonus na <strong>3</strong>.
            </div>
            @if (!string.IsNullOrWhiteSpace(cashFlowError))
            {
                <div class="alert alert-danger">@cashFlowError</div>
            }

            @if (entries.Count == 0)
            {
                @if (mortgageResult.MonthlyPayment == 0 && monthlySavingsContribution == 0 && monthlyInvestmentContribution == 0)
                {
                    <div class="empty-state">Pridaj prvý pravidelný príjem alebo výdavok.</div>
                }
            }
            @if (entries.Count > 0 || mortgageResult.MonthlyPayment > 0 || monthlySavingsContribution > 0 || monthlyInvestmentContribution > 0)
            {
                <div class="entry-list">
                    @if (mortgageResult.MonthlyPayment > 0)
                    {
                        <div class="entry-row mortgage-entry">
                            <span class="entry-dot expense-dot"></span>
                            <div>
                                <strong>Splátka hypotéky</strong>
                                <small>Automatický výdavok · od @mortgage.FirstPaymentDate.ToString("d. M. yyyy")</small>
                            </div>
                            <span class="entry-amount">- @Money(mortgageResult.MonthlyPayment)</span>
                            <a class="icon-link" title="Upraviť hypotéku" href="hypoteka">›</a>
                        </div>
                    }
                    @if (monthlySavingsContribution > 0)
                    {
                        <div class="entry-row savings-entry">
                            <span class="entry-dot savings-dot"></span>
                            <div>
                                <strong>Presun do sporenia</strong>
                                <small>@savingsRatePercent.ToString("N0") % z prebytku · nie je to výdavok majetku</small>
                            </div>
                            <span class="entry-amount savings-text">- @Money(monthlySavingsContribution)</span>
                            <a class="icon-link" title="Upraviť sporenie" href="sporenie">›</a>
                        </div>
                    }
                    @if (monthlyInvestmentContribution > 0)
                    {
                        <div class="entry-row investment-entry">
                            <span class="entry-dot investment-dot"></span>
                            <div>
                                <strong>Presun do investícií</strong>
                                <small>@investmentRatePercent.ToString("N0") % z prebytku · projekcia bez výnosu</small>
                            </div>
                            <span class="entry-amount investment-text">- @Money(monthlyInvestmentContribution)</span>
                            <span></span>
                        </div>
                    }
                    @foreach (var entry in entries.OrderBy(x => x.Type).ThenByDescending(x => x.MonthlyAmount))
                    {
                        <div class="entry-row">
                            <span class="entry-dot @(entry.Type == CashFlowType.Income ? "income-dot" : "expense-dot")"></span>
                            <div>
                                <strong>@entry.Name</strong>
                                <small>@EntrySchedule(entry)</small>
                            </div>
                            <span class="entry-amount @(entry.Type == CashFlowType.Income ? "income-text" : "")">
                                @(entry.Type == CashFlowType.Income ? "+" : "-") @Money(entry.MonthlyAmount)
                            </span>
                            <div class="entry-actions">
                                <button class="icon-button edit-icon-button" title="Upraviť" @onclick="() => BeginEdit(entry)">&#9998;</button>
                                <button class="icon-button" title="Odstrániť" @onclick="() => DeleteEntryAsync(entry.Id)">×</button>
                            </div>
                        </div>
                        @if (editingEntry?.Id == entry.Id)
                        {
                            var editEntry = editingEntry;
                            <EditForm Model="editEntry" OnValidSubmit="SaveEntryAsync" class="cashflow-form entry-edit-form">
                                <DataAnnotationsValidator />
                                <div class="field">
                                    <label>Názov</label>
                                    <InputText class="form-control" @bind-Value="editEntry.Name" />
                                </div>
                                <div class="field">
                                    <label>Suma pri každom pripísaní</label>
                                    <InputNumber class="form-control" @bind-Value="editEntry.MonthlyAmount" />
                                </div>
                                <div class="field">
                                    <label>Typ</label>
                                    <InputSelect class="form-select" @bind-Value="editEntry.Type">
                                        <option value="@CashFlowType.Income">Príjem</option>
                                        <option value="@CashFlowType.Expense">Výdavok</option>
                                    </InputSelect>
                                </div>
                                <div class="field">
                                    <label>Opakovať každých X mesiacov</label>
                                    <InputNumber class="form-control" @bind-Value="editEntry.IntervalMonths" placeholder="Jednorazová položka" />
                                </div>
                                <div class="field">
                                    <label>Prvý mesiac</label>
                                    <InputDate class="form-control" @bind-Value="editEntry.FirstOccurrenceMonth" />
                                </div>
                                <div class="entry-edit-actions">
                                    <button class="btn btn-secondary btn-small" type="button" @onclick="CancelEdit">Zrušiť</button>
                                    <button class="btn btn-primary btn-small" type="submit">Uložiť</button>
                                </div>
                            </EditForm>
                        }
                    }
                </div>
            }

            <div class="panel-header projection-heading">
                <div>
                    <p class="eyebrow">Projekcia cash flow</p>
                    <h2>Najbližších 12 mesiacov</h2>
                </div>
            </div>
            <div class="frequency-help projection-help">
                Počiatočný zostatok sporenia je <strong>@Money(totalSavings)</strong>.
                Dostupné spolu = zostatok sporenia + investície + hotovosť mimo sporenia.
                Mesačný úrok sa počíta zo zostatku na začiatku mesiaca.
            </div>
            <div class="cashflow-projection">
                <div class="cashflow-projection-row cashflow-projection-head">
                    <span>Mesiac</span>
                    <span>Príjmy</span>
                    <span>Výdavky</span>
                    <span>Sporenie</span>
                    <span>Investície</span>
                    <span>Voľné</span>
                    <span>Úrok</span>
                    <span>Sporenie spolu</span>
                    <span>Investície spolu</span>
                    <span>Hotovosť spolu</span>
                    <span>Dostupné spolu</span>
                </div>
                @for (var index = 0; index < cashFlowProjection.Count; index++)
                {
                    var row = cashFlowProjection[index];
                    var position = financialPositionProjection[index];
                    <div class="cashflow-projection-row">
                        <span>@MonthName(row.Month)</span>
                        <span class="income-text">+ @Money(row.Income)</span>
                        <span class="expense-text">- @Money(row.Expenses)</span>
                        <span class="savings-text">- @Money(row.SavingsContribution)</span>
                        <span class="investment-text">- @Money(row.InvestmentContribution)</span>
                        <strong class="@(row.FreeAmount >= 0 ? "income-text" : "expense-text")">@Money(row.FreeAmount)</strong>
                        <span class="income-text">+ @Money(position.NetInterest)</span>
                        <strong>@Money(position.SavingsBalance)</strong>
                        <strong class="investment-text">@Money(position.InvestmentBalance)</strong>
                        <strong>@Money(position.CashOutsideSavings)</strong>
                        <strong class="total-position">@Money(position.TotalAvailable)</strong>
                    </div>
                }
            </div>
        </article>

        <div class="stack">
            <article class="panel">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">Sporenie</p>
                        <h2>Všetky sporiace účty</h2>
                    </div>
                    <a class="text-link" href="sporenie">Upraviť</a>
                </div>
                <div class="big-number">@Money(totalSavings)</div>
                <div class="progress-track">
                    <span style="width: @SavingsProgress%"></span>
                </div>
                <div class="split-stat">
                    <span>Odhad úroku za 12 mesiacov</span>
                    <strong>@Money(projectedInterest)</strong>
                </div>
                <div class="split-stat">
                    <span>Odporúčaný účet pre ďalší vklad</span>
                    <strong>@(nextSavingsAllocation?.AccountName ?? "Nenastavené")</strong>
                </div>
            </article>

            <article class="panel">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">Hypotéka</p>
                        <h2>Plán kúpy nehnuteľnosti</h2>
                    </div>
                    <a class="text-link" href="hypoteka">Upraviť</a>
                </div>
                <div class="mortgage-highlight">
                    <span>Odhadovaná splátka</span>
                    <strong>@Money(mortgageResult.MonthlyPayment)</strong>
                    <small>mesačne na @mortgage.TermYears rokov</small>
                </div>
                <div class="two-cols">
                    <div><span>Výška úveru</span><strong>@Money(mortgageResult.Principal)</strong></div>
                    <div><span>LTV</span><strong>@mortgageResult.LtvPercent.ToString("N1") %</strong></div>
                </div>
            </article>
        </div>
    </section>
}

@code {
    private readonly CultureInfo culture = CultureInfo.GetCultureInfo("sk-SK");
    private readonly List<CashFlowEntry> entries = [];
    private CashFlowEntry newEntry = CreateNewEntry();
    private IReadOnlyList<CashFlowProjectionRow> cashFlowProjection = [];
    private IReadOnlyList<FinancialPositionProjectionRow> financialPositionProjection = [];
    private List<SavingsAccount> savingsAccounts = [];
    private MortgagePlan mortgage = new();
    private MortgageResult mortgageResult = new(0, 0, 0, 0);
    private string userId = "";
    private string currency = "CZK";
    private string? cashFlowError;
    private CashFlowEntry? editingEntry;
    private bool loading = true;
    private decimal monthlyIncome;
    private decimal averageMonthlyIncome;
    private decimal monthlyExpenses;
    private decimal monthlyFreeBeforeSavings;
    private decimal monthlyFree;
    private decimal projectedInterest;
    private decimal totalSavings;
    private decimal savingsRatePercent = 100m;
    private decimal investmentRatePercent;
    private decimal currentInvestmentBalance;
    private decimal monthlySavingsContribution;
    private decimal monthlyInvestmentContribution;
    private SavingsAllocation? nextSavingsAllocation;
    private DateTime freeCashTargetDate = DateTime.Today.AddMonths(12);

    private int CurrentMonthIncomeCount => entries.Count(x =>
        x.Type == CashFlowType.Income && FinancialCalculator.OccursInMonth(x, DateTime.Today));
    private int CurrentMonthExpenseCount =>
        entries.Count(x => x.Type == CashFlowType.Expense && FinancialCalculator.OccursInMonth(x, DateTime.Today)) +
        (FinancialCalculator.CalculateMortgagePaymentForMonth(mortgage, DateTime.Today) > 0 ? 1 : 0);
    private decimal SavingsProgress => Math.Min(100m, totalSavings / 1_000_000m * 100m);
    private FinancialPositionForecast PositionForecast => FinancialCalculator.ForecastFinancialPosition(
        entries,
        savingsAccounts,
        DateTime.Today,
        freeCashTargetDate,
        mortgage,
        savingsRatePercent,
        investmentRatePercent,
        currentInvestmentBalance);
    private decimal ForecastChartTotal => PositionForecast.SavingsBalance + PositionForecast.InvestmentBalance;
    private decimal SavingsRateInput
    {
        get => savingsRatePercent;
        set
        {
            savingsRatePercent = Math.Clamp(value, 0m, 100m);
            investmentRatePercent = 100m - savingsRatePercent;
        }
    }
    private decimal InvestmentRateInput
    {
        get => investmentRatePercent;
        set
        {
            investmentRatePercent = Math.Clamp(value, 0m, 100m);
            savingsRatePercent = 100m - investmentRatePercent;
        }
    }
    private decimal SavingsChartShare => ForecastChartTotal <= 0
        ? 0
        : PositionForecast.SavingsBalance / ForecastChartTotal * 100m;
    private string ForecastChartStyle =>
        $"--savings-share: {SavingsChartShare.ToString(CultureInfo.InvariantCulture)}%;";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        userId = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
        newEntry.UserId = userId;
        await LoadAsync();
        loading = false;
    }

    private async Task LoadAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        entries.Clear();
        entries.AddRange(await db.CashFlowEntries.Where(x => x.UserId == userId).ToListAsync());
        var userSettings = await db.Users.Where(x => x.Id == userId)
            .Select(x => new
            {
                x.PreferredCurrency,
                x.SavingsRatePercent,
                x.InvestmentRatePercent,
                x.InvestmentBalance
            })
            .SingleAsync();
        currency = userSettings.PreferredCurrency;
        savingsRatePercent = userSettings.SavingsRatePercent;
        investmentRatePercent = userSettings.InvestmentRatePercent;
        currentInvestmentBalance = userSettings.InvestmentBalance;
        savingsAccounts = await DataService.GetSavingsAccountsAsync(userId);
        mortgage = await DataService.GetOrCreateMortgagePlanAsync(userId);

        cashFlowProjection = FinancialCalculator.ProjectCashFlow(
            entries,
            DateTime.Today,
            mortgage,
            savingsRatePercent,
            investmentRatePercent);
        var currentMonth = cashFlowProjection.First();
        monthlyIncome = currentMonth.Income;
        monthlyExpenses = currentMonth.Expenses;
        monthlyFreeBeforeSavings = currentMonth.FreeBeforeSavings;
        monthlySavingsContribution = currentMonth.SavingsContribution;
        monthlyInvestmentContribution = currentMonth.InvestmentContribution;
        monthlyFree = currentMonth.FreeAmount;
        averageMonthlyIncome = cashFlowProjection.Average(x => x.Income);

        totalSavings = savingsAccounts.Sum(x => x.Balance);
        nextSavingsAllocation = FinancialCalculator.PlanSavingsAllocation(savingsAccounts, 1m).Allocations.FirstOrDefault();
        financialPositionProjection = FinancialCalculator.ProjectFinancialPosition(
            entries,
            savingsAccounts,
            DateTime.Today,
            mortgage,
            savingsRatePercent,
            investmentRatePercent,
            currentInvestmentBalance);
        projectedInterest = financialPositionProjection.Count == 0
            ? 0
            : financialPositionProjection[^1].CumulativeNetInterest;
        mortgageResult = FinancialCalculator.CalculateMortgage(mortgage);
    }

    private async Task SaveSavingsRateAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var user = await db.Users.SingleAsync(x => x.Id == userId);
        user.SavingsRatePercent = Math.Clamp(savingsRatePercent, 0m, 100m);
        user.InvestmentRatePercent = 100m - user.SavingsRatePercent;
        user.InvestmentBalance = Math.Max(0m, currentInvestmentBalance);
        savingsRatePercent = user.SavingsRatePercent;
        investmentRatePercent = user.InvestmentRatePercent;
        currentInvestmentBalance = user.InvestmentBalance;
        await db.SaveChangesAsync();
        await LoadAsync();
    }

    private async Task AddEntryAsync()
    {
        try
        {
            cashFlowError = null;
            newEntry.FirstOccurrenceMonth = new DateTime(
                newEntry.FirstOccurrenceMonth.Year,
                newEntry.FirstOccurrenceMonth.Month,
                1);
            await using var db = await DbFactory.CreateDbContextAsync();
            db.CashFlowEntries.Add(newEntry);
            await db.SaveChangesAsync();
            newEntry = CreateNewEntry();
            newEntry.UserId = userId;
            await LoadAsync();
        }
        catch (DbUpdateException)
        {
            cashFlowError = "Položku sa nepodarilo uložiť. Reštartuj aplikáciu a skús to znova.";
        }
    }

    private async Task DeleteEntryAsync(int id)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entry = await db.CashFlowEntries.SingleOrDefaultAsync(x => x.Id == id && x.UserId == userId);
        if (entry is not null)
        {
            db.CashFlowEntries.Remove(entry);
            await db.SaveChangesAsync();
            if (editingEntry?.Id == id)
            {
                editingEntry = null;
            }
            await LoadAsync();
        }
    }

    private void BeginEdit(CashFlowEntry entry)
    {
        cashFlowError = null;
        editingEntry = new CashFlowEntry
        {
            Id = entry.Id,
            UserId = userId,
            Name = entry.Name,
            MonthlyAmount = entry.MonthlyAmount,
            Type = entry.Type,
            IntervalMonths = entry.IntervalMonths,
            FirstOccurrenceMonth = entry.FirstOccurrenceMonth
        };
    }

    private void CancelEdit()
    {
        editingEntry = null;
        cashFlowError = null;
    }

    private async Task SaveEntryAsync()
    {
        if (editingEntry is null)
        {
            return;
        }

        try
        {
            cashFlowError = null;
            editingEntry.FirstOccurrenceMonth = new DateTime(
                editingEntry.FirstOccurrenceMonth.Year,
                editingEntry.FirstOccurrenceMonth.Month,
                1);

            await using var db = await DbFactory.CreateDbContextAsync();
            var storedEntry = await db.CashFlowEntries.SingleOrDefaultAsync(
                x => x.Id == editingEntry.Id && x.UserId == userId);
            if (storedEntry is null)
            {
                cashFlowError = "Položku sa nepodarilo nájsť.";
                editingEntry = null;
                await LoadAsync();
                return;
            }

            storedEntry.Name = editingEntry.Name;
            storedEntry.MonthlyAmount = editingEntry.MonthlyAmount;
            storedEntry.Type = editingEntry.Type;
            storedEntry.IntervalMonths = editingEntry.IntervalMonths;
            storedEntry.FirstOccurrenceMonth = editingEntry.FirstOccurrenceMonth;

            await db.SaveChangesAsync();
            editingEntry = null;
            await LoadAsync();
        }
        catch (DbUpdateException)
        {
            cashFlowError = "Zmeny položky sa nepodarilo uložiť. Reštartuj aplikáciu a skús to znova.";
        }
    }

    private string EntrySchedule(CashFlowEntry entry)
    {
        if (entry.IntervalMonths is null)
        {
            return $"{(entry.Type == CashFlowType.Income ? "Príjem" : "Výdavok")} · jednorazovo · {MonthName(entry.FirstOccurrenceMonth)}";
        }

        var frequency = entry.IntervalMonths switch
        {
            1 => "mesačne",
            3 => "kvartálne",
            6 => "polročne",
            12 => "ročne",
            _ => $"každých {entry.IntervalMonths} mes."
        };
        var next = Enumerable.Range(0, 240)
            .Select(offset => DateTime.Today.AddMonths(offset))
            .Cast<DateTime?>()
            .FirstOrDefault(month => FinancialCalculator.OccursInMonth(entry, month!.Value));
        var nextText = next is null ? "mimo projekcie" : MonthName(next.Value);
        return $"{(entry.Type == CashFlowType.Income ? "Príjem" : "Výdavok")} · {frequency} · najbližšie {nextText}";
    }

    private static CashFlowEntry CreateNewEntry() => new()
    {
        Type = CashFlowType.Income,
        FirstOccurrenceMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1)
    };

    private string MonthName(DateTime month) => month.ToString("MMM yyyy", culture);
    private string Money(decimal value) => $"{value.ToString("N0", culture)} {currency}";
}
