@page "/"
@attribute [Authorize]
@rendermode InteractiveServer

@using System.Globalization
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject FinancialDataService DataService

<PageTitle>Finančný prehľad</PageTitle>

@if (loading)
{
    <div class="loading-state">Načítavam finančný prehľad...</div>
}
else
{
    <header class="page-heading">
        <div>
            <p class="eyebrow">Dashboard</p>
            <h1>Financie bez zbytočností</h1>
            <p class="muted">Aktuálny odhad a vývoj pri nastavenom cashflow.</p>
        </div>
        <span class="date-chip">@DateTime.Today.ToString("d. M. yyyy", culture)</span>
    </header>

    <section class="dashboard-hero-grid">
        <article class="panel today-position">
            <div class="panel-header">
                <div>
                    <div class="date-estimate-control">
                        <p class="eyebrow date-estimate-heading">
                            Predpokladané financie k
                            <button type="button" @onclick="TogglePositionDatePicker">@PositionDateLabel</button>
                        </p>
                        @if (showPositionDatePicker)
                        {
                            <div class="date-picker-popover">
                                <label>Vyber dátum</label>
                                <input class="compact-date-input" type="date" min="@TodayInputValue"
                                       @bind="selectedPositionDate" @bind:after="ApplyPositionDate" />
                                @if (selectedPositionDate.Date != DateTime.Today)
                                {
                                    <button class="date-picker-today" type="button" @onclick="ResetPositionDate">Použiť dnešný dátum</button>
                                }
                            </div>
                        }
                    </div>
                    <h2>Sporenie a investície</h2>
                </div>
                <strong class="hero-total">@Money(SelectedPositionTotal)</strong>
            </div>
            <div class="today-position-content">
                <div class="interactive-pie large-portfolio-pie">
                    <svg viewBox="0 0 100 100">
                        <circle class="pie-track" cx="50" cy="50" r="38"></circle>
                        <circle class="pie-segment savings-segment" cx="50" cy="50" r="38" pathLength="100"
                                stroke-dasharray="@PieDash(SavingsTodayShare)" stroke-dashoffset="0"
                                @onmouseenter='() => SetTodayPieInfo("Sporenie", SelectedSavingsBalance, SavingsTodayShare)'
                                @onmouseleave="ClearTodayPieInfo"><title>Sporenie: @Money(SelectedSavingsBalance)</title></circle>
                        <circle class="pie-segment investment-segment" cx="50" cy="50" r="38" pathLength="100"
                                stroke-dasharray="@PieDash(InvestmentTodayShare)" stroke-dashoffset="@PieOffset(SavingsTodayShare)"
                                @onmouseenter='() => SetTodayPieInfo("Investície", SelectedInvestmentBalance, InvestmentTodayShare)'
                                @onmouseleave="ClearTodayPieInfo"><title>Investície: @Money(SelectedInvestmentBalance)</title></circle>
                    </svg>
                    <span>@todayPieLabel<small>@todayPieDetail</small></span>
                </div>
                <div class="today-balances">
                    <a href="sporenie">
                        <i class="savings-swatch"></i>
                        <span>Sporenie<small>potvrdené + dopočítané</small></span>
                        <strong>@Money(SelectedSavingsBalance)</strong>
                    </a>
                    <a href="investicie">
                        <i class="investment-swatch"></i>
                        <span>Investície<small>bez predpokladaného výnosu</small></span>
                        <strong>@Money(SelectedInvestmentBalance)</strong>
                    </a>
                </div>
            </div>
            <div class="balance-confirmation-strip">
                <span><i class="savings-swatch"></i>Sporenie naposledy potvrdené <strong>@DateTimeText(currentSavingsPosition.ConfirmedAt)</strong></span>
                <span><i class="investment-swatch"></i>Investície naposledy potvrdené <strong>@DateTimeText(currentInvestmentPosition.ConfirmedAt)</strong></span>
                <span><i class="cash-swatch"></i>Cash <strong>manuálne neevidovaný</strong></span>
            </div>
        </article>

        <article class="panel cashflow-widget">
            <div class="panel-header">
                <div>
                    <p class="eyebrow">Cash flow tento mesiac</p>
                    <h2>@MonthName(DateTime.Today)</h2>
                </div>
                <a class="gear-link" title="Nastaviť príjmy a výdavky" href="cashflow">⚙</a>
            </div>
            <div class="cashflow-widget-total @(monthlyFreeBeforeAllocation >= 0 ? "income-text" : "expense-text")">
                @Money(monthlyFreeBeforeAllocation)
                <small>prebytok pred rozdelením</small>
            </div>
            <div class="widget-stats">
                <span>Príjmy <strong class="income-text">+ @Money(monthlyIncome)</strong></span>
                <span>Výdavky <strong class="expense-text">- @Money(monthlyExpenses)</strong></span>
                <span>Po rozdelení ostane cash <strong>@Money(monthlyCash)</strong></span>
            </div>
            <a class="text-link" href="cashflow">Spravovať príjmy a výdavky →</a>
        </article>
    </section>

    <section class="panel allocation-widget">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Aktuálne nastavenie sporenia</p>
                <h2>Rozdelenie kladného mesačného prebytku</h2>
            </div>
            <button class="gear-button" title="Upraviť rozdelenie" type="button" @onclick="OpenAllocationModal">⚙</button>
        </div>
        <div class="allocation-widget-content">
            <div class="interactive-pie allocation-pie">
                <svg viewBox="0 0 100 100">
                    <circle class="pie-track" cx="50" cy="50" r="38"></circle>
                    <circle class="pie-segment savings-segment" cx="50" cy="50" r="38" pathLength="100" stroke-dasharray="@PieDash(savingsRatePercent)" stroke-dashoffset="0"
                            @onmouseenter='() => SetAllocationPieInfo("Sporenie", savingsRatePercent)' @onmouseleave="ClearAllocationPieInfo"><title>Sporenie: @savingsRatePercent.ToString("N0") %</title></circle>
                    <circle class="pie-segment investment-segment" cx="50" cy="50" r="38" pathLength="100" stroke-dasharray="@PieDash(investmentRatePercent)" stroke-dashoffset="@PieOffset(savingsRatePercent)"
                            @onmouseenter='() => SetAllocationPieInfo("Investície", investmentRatePercent)' @onmouseleave="ClearAllocationPieInfo"><title>Investície: @investmentRatePercent.ToString("N0") %</title></circle>
                    <circle class="pie-segment cash-segment" cx="50" cy="50" r="38" pathLength="100" stroke-dasharray="@PieDash(CashRatePercent)" stroke-dashoffset="@PieOffset(savingsRatePercent + investmentRatePercent)"
                            @onmouseenter='() => SetAllocationPieInfo("Cash", CashRatePercent)' @onmouseleave="ClearAllocationPieInfo"><title>Cash: @CashRatePercent.ToString("N0") %</title></circle>
                </svg>
                <span>@allocationPieLabel<small>@allocationPieDetail</small></span>
            </div>
            <div class="allocation-cards">
                <div><i class="savings-swatch"></i><span>Sporenie</span><strong>@savingsRatePercent.ToString("N0") %</strong><small>@Money(monthlySavingsContribution) tento mesiac</small></div>
                <div><i class="investment-swatch"></i><span>Investície</span><strong>@investmentRatePercent.ToString("N0") %</strong><small>@Money(monthlyInvestmentContribution) tento mesiac</small></div>
                <div><i class="cash-swatch"></i><span>Cash</span><strong>@CashRatePercent.ToString("N0") %</strong><small>@Money(monthlyCash) tento mesiac</small></div>
            </div>
        </div>
    </section>

    <section class="panel development-panel">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Predpokladaný vývoj</p>
                <h2>Najbližších 12 mesiacov</h2>
            </div>
            <span class="balance-pill chart-value-pill @ChartHeaderCssClass">@Money(ChartHeaderValue)</span>
        </div>
        <div class="chart-series-switcher" role="group" aria-label="Zobrazená časť financií">
            @foreach (var option in ChartSeriesOptions)
            {
                <button class="@(selectedChartSeries.Contains(option.Series) ? "active" : "")" type="button"
                        @onclick="() => ToggleChartSeries(option.Series)">
                    <i class="@option.CssClass"></i>@option.Label
                </button>
            }
        </div>
        <div class="development-chart">
            <svg viewBox="0 0 1100 330" role="img" aria-label="Graf predpokladaného vývoja financií">
                @foreach (var gridline in ChartGridlines)
                {
                    <line class="horizontal-gridline" x1="82" y1="@Svg(gridline.Y)" x2="1070" y2="@Svg(gridline.Y)"></line>
                    <foreignObject class="axis-value-object" x="0" y="@Svg(gridline.Y - 9)" width="72" height="18">
                        <div class="axis-value">@CompactMoney(gridline.Value)</div>
                    </foreignObject>
                }
                @foreach (var point in ChartPoints)
                {
                    <line class="vertical-gridline" x1="@Svg(point.X)" y1="20" x2="@Svg(point.X)" y2="270"></line>
                    <foreignObject x="@Svg(point.X - 35)" y="282" width="70" height="42">
                        <div class="axis-month">@point.Month.ToString("MMM", culture)<small>@point.Month.Year</small></div>
                    </foreignObject>
                }
                @foreach (var series in SelectedSeriesData)
                {
                    <polyline class="chart-line @SeriesCssClass(series.Series)" points="@PointsString(series.Points)"></polyline>
                    @foreach (var point in series.Points)
                    {
                        <circle class="chart-point @SeriesCssClass(series.Series)" cx="@Svg(point.X)" cy="@Svg(point.Y)" r="6"
                                @onmouseenter="() => ShowChartTooltip(point.Month)" @onmouseleave="HideChartTooltip">
                            <title>@SeriesLabel(series.Series) · @MonthName(point.Month): @Money(point.Value)</title>
                        </circle>
                    }
                }
                @if (hoveredChartMonth is not null)
                {
                    var tooltipPoints = TooltipPoints;
                    var anchor = tooltipPoints[0];
                    <foreignObject class="chart-tooltip-object" x="@Svg(TooltipX(anchor))" y="@Svg(TooltipY(anchor, tooltipPoints.Count))" width="200" height="@Svg(48 + tooltipPoints.Count * 22)">
                        <div class="chart-tooltip">
                            <small>@MonthName(anchor.Point.Month)</small>
                            @foreach (var item in tooltipPoints)
                            {
                                <span><i class="@SeriesSwatchClass(item.Series)"></i>@SeriesLabel(item.Series)<strong>@Money(item.Point.Value)</strong></span>
                            }
                        </div>
                    </foreignObject>
                }
            </svg>
            <p class="chart-help">Prejdi kurzorom na bod pre presné hodnoty zvolených sérií.</p>
        </div>
        <div class="monthly-calendar">
            @for (var index = 0; index < financialPositionProjection.Count; index++)
            {
                var position = financialPositionProjection[index];
                var cashflow = cashFlowProjection[index];
                <article class="month-card">
                    <header><span>@position.Month.ToString("MMM", culture)</span><small>@position.Month.Year</small></header>
                    <strong>@Money(position.TotalAvailable)</strong>
                    <div><span>Sporenie</span><b>@Money(position.SavingsBalance)</b></div>
                    <div><span>Investície</span><b>@Money(position.InvestmentBalance)</b></div>
                    <div><span>Cash</span><b>@Money(position.CashOutsideSavings)</b></div>
                    <button class="month-cashflow-button @(cashflow.FreeBeforeSavings >= 0 ? "income-text" : "expense-text")"
                            type="button" @onclick="() => OpenCashFlowDetail(cashflow)">
                        Cashflow @Money(cashflow.FreeBeforeSavings)
                    </button>
                </article>
            }
        </div>
    </section>

    @if (selectedCashFlow is not null)
    {
        <div class="modal-backdrop-custom" @onclick="CloseCashFlowDetail">
            <section class="cashflow-detail-modal" @onclick:stopPropagation="true">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">Mesačný cash flow</p>
                        <h2>@MonthName(selectedCashFlow.Month)</h2>
                    </div>
                    <button class="icon-button" type="button" @onclick="CloseCashFlowDetail">×</button>
                </div>

                <div class="cashflow-detail-section">
                    <h3>Príjmy <strong class="income-text">+ @Money(selectedCashFlow.Income)</strong></h3>
                    @foreach (var entry in SelectedIncomeEntries)
                    {
                        <div class="cashflow-detail-row"><span>@entry.Name</span><strong class="income-text">+ @Money(entry.MonthlyAmount)</strong></div>
                    }
                    @if (SelectedIncomeEntries.Count == 0) { <p class="cashflow-detail-empty">Žiadne príjmy.</p> }
                </div>

                <div class="cashflow-detail-section">
                    <h3>Výdavky <strong class="expense-text">- @Money(selectedCashFlow.Expenses)</strong></h3>
                    @foreach (var entry in SelectedExpenseEntries)
                    {
                        <div class="cashflow-detail-row"><span>@entry.Name</span><strong class="expense-text">- @Money(entry.MonthlyAmount)</strong></div>
                    }
                    @if (selectedCashFlow.MortgagePayment > 0)
                    {
                        <div class="cashflow-detail-row"><span>Automatická splátka hypotéky</span><strong class="expense-text">- @Money(selectedCashFlow.MortgagePayment)</strong></div>
                    }
                    @if (SelectedExpenseEntries.Count == 0 && selectedCashFlow.MortgagePayment == 0) { <p class="cashflow-detail-empty">Žiadne výdavky.</p> }
                </div>

                <div class="cashflow-detail-result">
                    <div><span>Prebytok pred rozdelením</span><strong>@Money(selectedCashFlow.FreeBeforeSavings)</strong></div>
                    <div><span>Do sporenia</span><strong class="savings-text">- @Money(selectedCashFlow.SavingsContribution)</strong></div>
                    <div><span>Do investícií</span><strong class="investment-text">- @Money(selectedCashFlow.InvestmentContribution)</strong></div>
                    <div class="cashflow-detail-total"><span>Cash po rozdelení</span><strong>@Money(selectedCashFlow.FreeAmount)</strong></div>
                </div>
                <a class="text-link" href="cashflow">Upraviť príjmy a výdavky →</a>
            </section>
        </div>
    }

    @if (showAllocationModal)
    {
        <div class="modal-backdrop-custom" @onclick="CloseAllocationModal">
            <section class="allocation-modal" @onclick:stopPropagation="true">
                <div class="panel-header">
                    <div><p class="eyebrow">Nastavenie</p><h2>Rozdelenie prebytku</h2></div>
                    <button class="icon-button" type="button" @onclick="CloseAllocationModal">×</button>
                </div>
                <div class="interactive-pie allocation-pie modal-pie">
                    <svg viewBox="0 0 100 100">
                        <circle class="pie-track" cx="50" cy="50" r="38"></circle>
                        <circle class="pie-segment savings-segment" cx="50" cy="50" r="38" pathLength="100" stroke-dasharray="@PieDash(draftSavingsRate)" stroke-dashoffset="0"><title>Sporenie: @draftSavingsRate.ToString("N0") %</title></circle>
                        <circle class="pie-segment investment-segment" cx="50" cy="50" r="38" pathLength="100" stroke-dasharray="@PieDash(draftInvestmentRate)" stroke-dashoffset="@PieOffset(draftSavingsRate)"><title>Investície: @draftInvestmentRate.ToString("N0") %</title></circle>
                        <circle class="pie-segment cash-segment" cx="50" cy="50" r="38" pathLength="100" stroke-dasharray="@PieDash(DraftCashRate)" stroke-dashoffset="@PieOffset(draftSavingsRate + draftInvestmentRate)"><title>Cash: @DraftCashRate.ToString("N0") %</title></circle>
                    </svg>
                    <span>@DraftCashRate.ToString("N0") %<small>cash</small></span>
                </div>
                <div class="modal-fields">
                    <div class="field"><label>Sporenie (%)</label><input class="form-control" type="number" min="0" max="100" @bind="draftSavingsRate" /></div>
                    <div class="field"><label>Investície (%)</label><input class="form-control" type="number" min="0" max="100" @bind="draftInvestmentRate" /></div>
                    <div class="field"><label>Cash (%)</label><input class="form-control" value="@DraftCashRate.ToString("N0")" disabled /></div>
                </div>
                @if (!string.IsNullOrWhiteSpace(allocationError))
                {
                    <div class="alert alert-danger">@allocationError</div>
                }
                <p class="muted planning-help">Cash je zvyšok do 100 %. Investície sa v prognóze počítajú bez výnosu.</p>
                <div class="modal-actions">
                    <button class="btn btn-secondary" type="button" @onclick="CloseAllocationModal">Zrušiť</button>
                    <button class="btn btn-primary" type="button" @onclick="SaveAllocationAsync">Uložiť rozdelenie</button>
                </div>
            </section>
        </div>
    }
}

@code {
    private readonly CultureInfo culture = CultureInfo.GetCultureInfo("sk-SK");
    private readonly List<CashFlowEntry> entries = [];
    private IReadOnlyList<CashFlowProjectionRow> cashFlowProjection = [];
    private IReadOnlyList<FinancialPositionProjectionRow> financialPositionProjection = [];
    private List<SavingsAccount> estimatedSavingsAccounts = [];
    private MortgagePlan mortgage = new();
    private CurrentSavingsPosition currentSavingsPosition = new(DateTime.Today, 0, 0, 0, 0, new Dictionary<int, decimal>());
    private CurrentInvestmentPosition currentInvestmentPosition = new(null, 0, 0, 0);
    private string userId = "";
    private string currency = "CZK";
    private bool loading = true;
    private bool showAllocationModal;
    private bool showPositionDatePicker;
    private CashFlowProjectionRow? selectedCashFlow;
    private string? allocationError;
    private decimal savingsRatePercent;
    private decimal investmentRatePercent;
    private decimal draftSavingsRate;
    private decimal draftInvestmentRate;
    private decimal monthlyIncome;
    private decimal monthlyExpenses;
    private decimal monthlyFreeBeforeAllocation;
    private decimal monthlySavingsContribution;
    private decimal monthlyInvestmentContribution;
    private decimal monthlyCash;
    private string todayPieLabel = "Spolu";
    private string todayPieDetail = "";
    private string allocationPieLabel = "100 %";
    private string allocationPieDetail = "prebytok";
    private readonly HashSet<ChartSeries> selectedChartSeries = [ChartSeries.Total];
    private DateTime? hoveredChartMonth;
    private DateTime selectedPositionDate = DateTime.Today;
    private FinancialPositionForecast selectedPositionForecast = new(DateTime.Today, 0, 0, 0, 0, 0, 0, 0);

    private decimal ExpectedTodayTotal => currentSavingsPosition.EstimatedCurrentBalance + currentInvestmentPosition.EstimatedCurrentBalance;
    private decimal SelectedSavingsBalance => selectedPositionDate.Date <= DateTime.Today
        ? currentSavingsPosition.EstimatedCurrentBalance
        : selectedPositionForecast.SavingsBalance;
    private decimal SelectedInvestmentBalance => selectedPositionDate.Date <= DateTime.Today
        ? currentInvestmentPosition.EstimatedCurrentBalance
        : selectedPositionForecast.InvestmentBalance;
    private decimal SelectedPositionTotal => SelectedSavingsBalance + SelectedInvestmentBalance;
    private decimal SavingsTodayShare => SelectedPositionTotal <= 0 ? 0 : SelectedSavingsBalance / SelectedPositionTotal * 100m;
    private decimal InvestmentTodayShare => SelectedPositionTotal <= 0 ? 0 : SelectedInvestmentBalance / SelectedPositionTotal * 100m;
    private string PositionDateLabel => selectedPositionDate.Date == DateTime.Today
        ? "dnešnému dňu"
        : selectedPositionDate.ToString("d. M. yyyy", culture);
    private string TodayInputValue => DateTime.Today.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
    private decimal CashRatePercent => Math.Max(0m, 100m - savingsRatePercent - investmentRatePercent);
    private decimal DraftCashRate => Math.Max(0m, 100m - Math.Clamp(draftSavingsRate, 0m, 100m) - Math.Clamp(draftInvestmentRate, 0m, 100m));
    private decimal FinalProjectedTotal => financialPositionProjection.LastOrDefault()?.TotalAvailable ?? ExpectedTodayTotal;
    private decimal ChartHeaderValue => selectedChartSeries.Count == 1
        ? ChartValues(selectedChartSeries.Single()).LastOrDefault()
        : FinalProjectedTotal;
    private string ChartHeaderCssClass => selectedChartSeries.Count == 1
        ? SeriesCssClass(selectedChartSeries.Single())
        : SeriesCssClass(ChartSeries.Total);
    private IReadOnlyList<ChartSeriesOption> ChartSeriesOptions =>
    [
        new(ChartSeries.Total, "Spolu", "total-swatch"),
        new(ChartSeries.Savings, "Sporenie", "savings-swatch"),
        new(ChartSeries.Investments, "Investície", "investment-swatch"),
        new(ChartSeries.Cash, "Cash", "cash-swatch")
    ];
    private IReadOnlyList<ChartSeriesData> SelectedSeriesData => CreateSelectedSeriesData();
    private IReadOnlyList<TooltipPoint> TooltipPoints => hoveredChartMonth is null
        ? []
        : SelectedSeriesData.Select(series => new TooltipPoint(
                series.Series,
                series.Points.Single(point => point.Month.Year == hoveredChartMonth.Value.Year && point.Month.Month == hoveredChartMonth.Value.Month)))
            .ToList();
    private string DevelopmentChartPoints => CreateChartPoints();
    private string DevelopmentAreaPoints => $"82,270 {DevelopmentChartPoints} 1070,270";
    private IReadOnlyList<ChartPoint> ChartPoints => CreateChartData();
    private IReadOnlyList<ChartGridline> ChartGridlines => CreateGridlines();
    private IReadOnlyList<CashFlowEntry> SelectedIncomeEntries => SelectedEntries(CashFlowType.Income);
    private IReadOnlyList<CashFlowEntry> SelectedExpenseEntries => SelectedEntries(CashFlowType.Expense);

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        userId = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
        await LoadAsync();
        loading = false;
    }

    private async Task LoadAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        entries.Clear();
        entries.AddRange(await db.CashFlowEntries.Where(x => x.UserId == userId).ToListAsync());
        var user = await db.Users.SingleAsync(x => x.Id == userId);
        currency = user.PreferredCurrency;
        savingsRatePercent = user.SavingsRatePercent;
        investmentRatePercent = user.InvestmentRatePercent;
        var accounts = await DataService.GetSavingsAccountsAsync(userId);
        mortgage = await DataService.GetOrCreateMortgagePlanAsync(userId);

        currentSavingsPosition = FinancialCalculator.CalculateCurrentSavingsPosition(entries, accounts, DateTime.Today, mortgage, savingsRatePercent, investmentRatePercent);
        currentInvestmentPosition = FinancialCalculator.CalculateCurrentInvestmentPosition(entries, user.InvestmentBalance, user.InvestmentBalanceUpdatedAtUtc, DateTime.Today, mortgage, savingsRatePercent, investmentRatePercent);
        estimatedSavingsAccounts = CreateAccountsWithBalances(accounts, currentSavingsPosition.AccountBalances);
        var currentMonth = FinancialCalculator.ProjectCashFlow(entries, DateTime.Today, mortgage, savingsRatePercent, investmentRatePercent, 1).First();
        cashFlowProjection = FinancialCalculator.ProjectCashFlow(entries, DateTime.Today.AddMonths(1), mortgage, savingsRatePercent, investmentRatePercent);
        financialPositionProjection = FinancialCalculator.ProjectFinancialPosition(entries, estimatedSavingsAccounts, DateTime.Today.AddMonths(1), mortgage, savingsRatePercent, investmentRatePercent, currentInvestmentPosition.EstimatedCurrentBalance);

        monthlyIncome = currentMonth.Income;
        monthlyExpenses = currentMonth.Expenses;
        monthlyFreeBeforeAllocation = currentMonth.FreeBeforeSavings;
        monthlySavingsContribution = currentMonth.SavingsContribution;
        monthlyInvestmentContribution = currentMonth.InvestmentContribution;
        monthlyCash = currentMonth.FreeAmount;
        RecalculateSelectedPosition();
        ClearTodayPieInfo();
        ClearAllocationPieInfo();
    }

    private void OpenAllocationModal()
    {
        draftSavingsRate = savingsRatePercent;
        draftInvestmentRate = investmentRatePercent;
        allocationError = null;
        showAllocationModal = true;
    }

    private void CloseAllocationModal() => showAllocationModal = false;
    private void ToggleChartSeries(ChartSeries series)
    {
        if (!selectedChartSeries.Remove(series)) selectedChartSeries.Add(series);
        if (selectedChartSeries.Count == 0) selectedChartSeries.Add(ChartSeries.Total);
        hoveredChartMonth = null;
    }
    private void ShowChartTooltip(DateTime month) => hoveredChartMonth = month;
    private void HideChartTooltip() => hoveredChartMonth = null;
    private void TogglePositionDatePicker() => showPositionDatePicker = !showPositionDatePicker;
    private void ResetPositionDate()
    {
        selectedPositionDate = DateTime.Today;
        ApplyPositionDate();
    }
    private void ApplyPositionDate()
    {
        if (selectedPositionDate.Date < DateTime.Today) selectedPositionDate = DateTime.Today;
        RecalculateSelectedPosition();
        ClearTodayPieInfo();
        showPositionDatePicker = false;
    }
    private void RecalculateSelectedPosition()
    {
        selectedPositionForecast = FinancialCalculator.ForecastFinancialPosition(
            entries,
            estimatedSavingsAccounts,
            DateTime.Today.AddMonths(1),
            selectedPositionDate,
            mortgage,
            savingsRatePercent,
            investmentRatePercent,
            currentInvestmentPosition.EstimatedCurrentBalance);
    }
    private void OpenCashFlowDetail(CashFlowProjectionRow row) => selectedCashFlow = row;
    private void CloseCashFlowDetail() => selectedCashFlow = null;

    private IReadOnlyList<CashFlowEntry> SelectedEntries(CashFlowType type)
        => selectedCashFlow is null
            ? []
            : entries.Where(entry => entry.Type == type && FinancialCalculator.OccursInMonth(entry, selectedCashFlow.Month))
                .OrderByDescending(entry => entry.MonthlyAmount)
                .ToList();

    private void SetTodayPieInfo(string label, decimal value, decimal share)
    {
        todayPieLabel = label;
        todayPieDetail = $"{share:N0} % · {Money(value)}";
    }

    private void ClearTodayPieInfo()
    {
        todayPieLabel = "Spolu";
        todayPieDetail = Money(SelectedPositionTotal);
    }

    private void SetAllocationPieInfo(string label, decimal share)
    {
        allocationPieLabel = label;
        allocationPieDetail = $"{share:N0} %";
    }

    private void ClearAllocationPieInfo()
    {
        allocationPieLabel = "100 %";
        allocationPieDetail = "prebytok";
    }

    private async Task SaveAllocationAsync()
    {
        draftSavingsRate = Math.Clamp(draftSavingsRate, 0m, 100m);
        draftInvestmentRate = Math.Clamp(draftInvestmentRate, 0m, 100m);
        if (draftSavingsRate + draftInvestmentRate > 100m)
        {
            allocationError = "Sporenie a investície môžu mať spolu najviac 100 %.";
            return;
        }
        await using var db = await DbFactory.CreateDbContextAsync();
        var user = await db.Users.SingleAsync(x => x.Id == userId);
        user.SavingsRatePercent = draftSavingsRate;
        user.InvestmentRatePercent = draftInvestmentRate;
        await db.SaveChangesAsync();
        showAllocationModal = false;
        await LoadAsync();
    }

    private string CreateChartPoints()
    {
        return string.Join(" ", ChartPoints.Select(point => $"{Svg(point.X)},{Svg(point.Y)}"));
    }

    private IReadOnlyList<ChartPoint> CreateChartData()
    {
        return CreateChartData(ChartSeries.Total);
    }

    private IReadOnlyList<ChartPoint> CreateChartData(ChartSeries series)
    {
        var values = ChartValues(series);
        var months = new[] { DateTime.Today }.Concat(financialPositionProjection.Select(x => x.Month)).ToArray();
        var allValues = selectedChartSeries.SelectMany(ChartValues).ToArray();
        var min = allValues.Min();
        var max = allValues.Max();
        var padding = Math.Max(10_000m, (max - min) * .12m);
        var chartMin = Math.Max(0m, min - padding);
        var chartMax = max + padding;
        var range = Math.Max(1m, chartMax - chartMin);
        return values.Select((value, index) => new ChartPoint(
            months[index],
            value,
            82m + index * 988m / Math.Max(1, values.Length - 1),
            270m - (value - chartMin) / range * 250m)).ToList();
    }

    private IReadOnlyList<ChartGridline> CreateGridlines()
    {
        var values = selectedChartSeries.SelectMany(ChartValues).ToArray();
        var min = values.Min();
        var max = values.Max();
        var padding = Math.Max(10_000m, (max - min) * .12m);
        var chartMin = Math.Max(0m, min - padding);
        var chartMax = max + padding;
        return Enumerable.Range(0, 5)
            .Select(index => new ChartGridline(20m + index * 62.5m, chartMax - index * (chartMax - chartMin) / 4m))
            .ToList();
    }

    private IReadOnlyList<ChartSeriesData> CreateSelectedSeriesData()
        => ChartSeriesOptions.Where(option => selectedChartSeries.Contains(option.Series))
            .Select(option => new ChartSeriesData(option.Series, CreateChartData(option.Series)))
            .ToList();

    private decimal[] ChartValues(ChartSeries series) => series switch
    {
        ChartSeries.Savings => new[] { currentSavingsPosition.EstimatedCurrentBalance }
            .Concat(financialPositionProjection.Select(x => x.SavingsBalance)).ToArray(),
        ChartSeries.Investments => new[] { currentInvestmentPosition.EstimatedCurrentBalance }
            .Concat(financialPositionProjection.Select(x => x.InvestmentBalance)).ToArray(),
        ChartSeries.Cash => new[] { 0m }.Concat(financialPositionProjection.Select(x => x.CashOutsideSavings)).ToArray(),
        _ => new[] { ExpectedTodayTotal }.Concat(financialPositionProjection.Select(x => x.TotalAvailable)).ToArray()
    };

    private static string PointsString(IReadOnlyList<ChartPoint> points) => string.Join(" ", points.Select(point => $"{Svg(point.X)},{Svg(point.Y)}"));
    private static string SeriesLabel(ChartSeries series) => series switch
    {
        ChartSeries.Savings => "Sporenie",
        ChartSeries.Investments => "Investície",
        ChartSeries.Cash => "Cash",
        _ => "Spolu"
    };
    private static string SeriesCssClass(ChartSeries series) => series switch
    {
        ChartSeries.Savings => "series-savings",
        ChartSeries.Investments => "series-investments",
        ChartSeries.Cash => "series-cash",
        _ => "series-total"
    };
    private static string SeriesSwatchClass(ChartSeries series) => series switch
    {
        ChartSeries.Savings => "savings-swatch",
        ChartSeries.Investments => "investment-swatch",
        ChartSeries.Cash => "cash-swatch",
        _ => "total-swatch"
    };
    private static decimal TooltipX(TooltipPoint item) => item.Point.X > 880m ? item.Point.X - 205m : item.Point.X + 10m;
    private static decimal TooltipY(TooltipPoint item, int count) => Math.Max(5m, item.Point.Y - 55m - count * 22m);

    private static List<SavingsAccount> CreateAccountsWithBalances(IEnumerable<SavingsAccount> accounts, IReadOnlyDictionary<int, decimal> balances)
        => accounts.Select(account => new SavingsAccount
        {
            Id = account.Id, UserId = account.UserId, Name = account.Name, BankName = account.BankName,
            Balance = balances.GetValueOrDefault(account.Id, account.Balance), BalanceUpdatedAtUtc = account.BalanceUpdatedAtUtc,
            InterestTaxPercent = account.InterestTaxPercent, MeetsBonusConditions = account.MeetsBonusConditions,
            UpdatedAtUtc = account.UpdatedAtUtc, RateTiers = account.RateTiers
        }).ToList();

    private static string PieDash(decimal share) => $"{Invariant(Math.Clamp(share, 0m, 100m))} {Invariant(100m - Math.Clamp(share, 0m, 100m))}";
    private static string PieOffset(decimal start) => Invariant(-Math.Clamp(start, 0m, 100m));
    private string CompactMoney(decimal value) => value >= 1_000_000m ? $"{value / 1_000_000m:N1} mil." : $"{value / 1_000m:N0} tis.";
    private static string Svg(decimal value) => value.ToString("0.##", CultureInfo.InvariantCulture);
    private static string Invariant(decimal value) => value.ToString("0.##", CultureInfo.InvariantCulture);
    private string MonthName(DateTime month) => month.ToString("MMM yyyy", culture);
    private string Money(decimal value) => $"{value.ToString("N0", culture)} {currency}";
    private string DateTimeText(DateTime? value) => value is null
        ? "zatiaľ nepotvrdené"
        : value.Value.ToLocalTime().ToString("d. M. yyyy HH:mm", culture);
    private sealed record ChartPoint(DateTime Month, decimal Value, decimal X, decimal Y);
    private sealed record ChartGridline(decimal Y, decimal Value);
    private sealed record ChartSeriesOption(ChartSeries Series, string Label, string CssClass);
    private sealed record ChartSeriesData(ChartSeries Series, IReadOnlyList<ChartPoint> Points);
    private sealed record TooltipPoint(ChartSeries Series, ChartPoint Point);
    private enum ChartSeries { Total, Savings, Investments, Cash }
}
